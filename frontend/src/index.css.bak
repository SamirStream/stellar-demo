/* ============================================
   The Signal — Stellar Escrow Demo
   Dark theme CSS
   ============================================ */

:root {
  --bg-primary: #0a0a0f;
  --bg-secondary: #12121a;
  --bg-card: #16161f;
  --bg-card-hover: #1a1a25;
  --bg-input: #1e1e2a;
  --border: #2a2a3a;
  --border-focus: #7c3aed;
  --text-primary: #f0f0f5;
  --text-secondary: #9ca3af;
  --text-muted: #6b7280;
  --accent: #7c3aed;
  --accent-light: #a78bfa;
  --accent-bg: rgba(124, 58, 237, 0.15);
  --green: #10b981;
  --green-bg: rgba(16, 185, 129, 0.15);
  --blue: #3b82f6;
  --blue-bg: rgba(59, 130, 246, 0.15);
  --red: #ef4444;
  --red-bg: rgba(239, 68, 68, 0.15);
  --yellow: #f59e0b;
  --yellow-bg: rgba(245, 158, 11, 0.15);
  --font-sans: 'Inter', system-ui, -apple-system, sans-serif;
  --font-mono: 'JetBrains Mono', 'Fira Code', monospace;
  --radius: 12px;
  --radius-sm: 8px;
  --shadow: 0 4px 24px rgba(0, 0, 0, 0.3);
}

* {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
}

body {
  font-family: var(--font-sans);
  background: var(--bg-primary);
  background-image:
    radial-gradient(ellipse at 20% 50%, rgba(124, 58, 237, 0.04) 0%, transparent 50%),
    radial-gradient(ellipse at 80% 20%, rgba(59, 130, 246, 0.03) 0%, transparent 50%);
  color: var(--text-primary);
  line-height: 1.6;
  min-height: 100vh;
  -webkit-font-smoothing: antialiased;
}

#root {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
}

/* ============================================
   Typography
   ============================================ */

h1, h2, h3, h4, h5 {
  color: var(--text-primary);
  font-weight: 600;
  line-height: 1.3;
}

h2 { font-size: 1.75rem; }
h3 { font-size: 1.25rem; margin-bottom: 0.5rem; }
h4 { font-size: 1rem; margin-bottom: 0.25rem; }

a {
  color: var(--accent-light);
  text-decoration: none;
  transition: color 0.2s;
}
a:hover {
  color: var(--accent);
}

/* ============================================
   Layout
   ============================================ */

.app {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
}

.app-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 1rem 2rem;
  background: rgba(18, 18, 26, 0.75);
  border-bottom: 1px solid rgba(255, 255, 255, 0.06);
  position: sticky;
  top: 0;
  z-index: 100;
  -webkit-backdrop-filter: blur(16px);
  backdrop-filter: blur(16px);
}

.header-left { display: flex; align-items: center; gap: 1rem; }
.header-right { display: flex; align-items: center; gap: 1rem; }

.logo {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  text-decoration: none;
}

.logo-img {
  width: 40px;
  height: 40px;
  border-radius: 10px;
  object-fit: contain;
}

.logo-text {
  display: flex;
  flex-direction: column;
}

.logo-title {
  font-weight: 700;
  font-size: 1.1rem;
  color: var(--text-primary);
  line-height: 1.2;
}

.logo-subtitle {
  font-size: 0.7rem;
  color: var(--text-muted);
  text-transform: uppercase;
  letter-spacing: 0.5px;
}

.testnet-badge {
  padding: 0.25rem 0.75rem;
  background: var(--yellow-bg);
  color: var(--yellow);
  border-radius: 999px;
  font-size: 0.7rem;
  font-weight: 700;
  letter-spacing: 1px;
}

.app-main {
  flex: 1;
  max-width: 900px;
  width: 100%;
  margin: 0 auto;
  padding: 2rem;
}

.app-footer {
  display: flex;
  flex-direction: column;
  gap: 1rem;
  padding: 1.5rem 2rem;
  border-top: 1px solid var(--border);
  font-size: 0.8rem;
  color: var(--text-muted);
}

.footer-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 1rem;
}

.footer-brand {
  display: flex;
  align-items: center;
  gap: 0.75rem;
}

.footer-logo {
  width: 32px;
  height: 32px;
  border-radius: 8px;
  object-fit: contain;
}

.footer-brand-name {
  display: block;
  font-weight: 700;
  font-size: 0.9rem;
  color: var(--text-primary);
  line-height: 1.2;
}

.footer-brand-tagline {
  display: block;
  font-size: 0.75rem;
  color: var(--text-muted);
}

.footer-socials {
  display: flex;
  align-items: center;
  gap: 0.5rem;
}

.footer-socials a {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 36px;
  height: 36px;
  border-radius: 8px;
  color: var(--text-muted);
  background: var(--surface);
  border: 1px solid var(--border);
  transition: all 0.2s ease;
}

.footer-socials a:hover {
  color: var(--accent-light);
  border-color: var(--accent);
  background: rgba(124, 58, 237, 0.1);
}

.footer-middle {
  display: flex;
  gap: 4rem;
  padding: 0.75rem 0;
}

.footer-links-group {
  display: flex;
  flex-direction: column;
  gap: 0.4rem;
}

.footer-links-title {
  font-weight: 600;
  font-size: 0.75rem;
  color: var(--text-secondary);
  text-transform: uppercase;
  letter-spacing: 0.05em;
  margin-bottom: 0.25rem;
}

.footer-links-group a {
  color: var(--text-muted);
  text-decoration: none;
  font-size: 0.8rem;
  transition: color 0.2s ease;
}

.footer-links-group a:hover {
  color: var(--accent-light);
}

.footer-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-top: 1rem;
  border-top: 1px solid var(--border);
}

.footer-copyright {
  font-size: 0.75rem;
  color: var(--text-muted);
}

.footer-powered {
  display: flex;
  align-items: center;
  font-size: 0.75rem;
  color: var(--text-muted);
}

.footer-powered svg {
  margin: 0 4px;
  vertical-align: -2px;
  color: var(--accent-light);
}

.separator { opacity: 0.3; }

/* ============================================
   Connect Prompt (landing)
   ============================================ */

.connect-prompt {
  text-align: center;
  padding: 4rem 2rem;
}

.connect-prompt-icon {
  font-size: 3rem;
  color: var(--accent);
  margin-bottom: 1.5rem;
}

.connect-prompt h2 {
  margin-bottom: 0.75rem;
  font-size: 2rem;
}

.connect-prompt p {
  color: var(--text-secondary);
  max-width: 480px;
  margin: 0 auto 2rem;
}

.connect-features {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 1rem;
  max-width: 500px;
  margin: 2.5rem auto 0;
}

.feature {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  padding: 1rem;
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: var(--radius-sm);
  font-size: 0.9rem;
  color: var(--text-secondary);
}

.feature-icon {
  font-size: 1.25rem;
  color: var(--accent-light);
  width: 24px;
  text-align: center;
}

/* ============================================
   Tabs
   ============================================ */

.tabs {
  display: flex;
  gap: 0.25rem;
  padding: 0.25rem;
  background: rgba(18, 18, 26, 0.6);
  border-radius: var(--radius);
  border: 1px solid rgba(255, 255, 255, 0.06);
  margin-bottom: 1.5rem;
  -webkit-backdrop-filter: blur(12px);
  backdrop-filter: blur(12px);
}

.tab {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 0.5rem;
  padding: 0.75rem 1rem;
  background: transparent;
  border: none;
  border-radius: var(--radius-sm);
  color: var(--text-muted);
  font-size: 0.9rem;
  font-weight: 500;
  cursor: pointer;
  transition: all 0.2s;
}

.tab:hover {
  color: var(--text-secondary);
  background: var(--bg-card);
}

.tab.active {
  background: var(--accent-bg);
  color: var(--accent-light);
  border: 1px solid rgba(124, 58, 237, 0.3);
}

.tab-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  transition: transform 0.2s;
}

.tab:hover .tab-icon {
  transform: scale(1.15);
}

.tab.active .tab-icon {
  transform: scale(1.1);
}

.tab-label {
  font-size: 0.85rem;
}

.tab-content {
  animation: fadeIn 0.2s ease;
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(4px); }
  to { opacity: 1; transform: translateY(0); }
}

@keyframes slideUp {
  from { opacity: 0; transform: translateY(12px); }
  to { opacity: 1; transform: translateY(0); }
}

@keyframes bounceIn {
  0% { opacity: 0; transform: scale(0.3); }
  50% { opacity: 1; transform: scale(1.05); }
  70% { transform: scale(0.95); }
  100% { transform: scale(1); }
}

@keyframes scaleIn {
  from { opacity: 0; transform: scale(0.8); }
  to { opacity: 1; transform: scale(1); }
}

@keyframes pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.5; }
}

@keyframes shimmer {
  0% { background-position: -200% 0; }
  100% { background-position: 200% 0; }
}

@keyframes dotPulse {
  0%, 100% { box-shadow: 0 0 4px var(--green); }
  50% { box-shadow: 0 0 12px var(--green); }
}

/* ============================================
   Cards
   ============================================ */

.card {
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  padding: 1.5rem;
  margin-bottom: 1rem;
}

.card-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 1rem;
}

.card-subtitle {
  color: var(--text-muted);
  font-size: 0.85rem;
  margin-bottom: 1.25rem;
}

.success-card {
  text-align: center;
  border-color: rgba(16, 185, 129, 0.3);
}

.success-card h3 { color: var(--green); margin-bottom: 1rem; }

.result-details {
  background: var(--bg-input);
  border-radius: var(--radius-sm);
  padding: 1rem;
  margin-bottom: 1rem;
  text-align: left;
}

.result-details p { margin-bottom: 0.5rem; font-size: 0.9rem; }
.result-details p:last-child { margin-bottom: 0; }

/* ============================================
   Form Elements
   ============================================ */

.form-group {
  margin-bottom: 1rem;
}

.form-group label {
  display: block;
  margin-bottom: 0.375rem;
  font-size: 0.85rem;
  font-weight: 500;
  color: var(--text-secondary);
}

input[type="text"],
input[type="number"],
input[type="email"],
textarea,
select {
  width: 100%;
  padding: 0.75rem 1rem;
  background: var(--bg-input);
  border: 1px solid var(--border);
  border-radius: var(--radius-sm);
  color: var(--text-primary);
  font-size: 0.9rem;
  font-family: var(--font-sans);
  transition: border-color 0.2s;
}

input:focus,
textarea:focus,
select:focus {
  outline: none;
  border-color: var(--border-focus);
  box-shadow: 0 0 0 3px rgba(124, 58, 237, 0.15);
}

input::placeholder {
  color: var(--text-muted);
}

.form-row {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
  gap: 1rem;
}

/* ============================================
   Buttons
   ============================================ */

button {
  cursor: pointer;
  font-family: var(--font-sans);
  font-weight: 600;
  transition: all 0.2s;
}

.btn-primary {
  width: 100%;
  padding: 0.875rem 1.5rem;
  background: linear-gradient(135deg, var(--accent), #a855f7);
  border: none;
  border-radius: var(--radius-sm);
  color: white;
  font-size: 0.95rem;
  margin-top: 0.5rem;
}

.btn-primary:hover:not(:disabled) {
  filter: brightness(1.1);
  transform: translateY(-1px);
}

.btn-primary:disabled {
  opacity: 0.5;
  cursor: not-allowed;
}

.btn-large {
  padding: 1rem 2.5rem;
  font-size: 1.1rem;
  width: auto;
}

.btn-secondary {
  padding: 0.75rem 1.5rem;
  background: var(--bg-input);
  border: 1px solid var(--border);
  border-radius: var(--radius-sm);
  color: var(--text-primary);
  font-size: 0.9rem;
}

.btn-secondary:hover:not(:disabled) {
  background: var(--bg-card-hover);
  border-color: var(--text-muted);
}

.btn-small {
  padding: 0.375rem 0.75rem;
  background: var(--accent-bg);
  border: 1px solid rgba(124, 58, 237, 0.3);
  border-radius: 6px;
  color: var(--accent-light);
  font-size: 0.75rem;
}

.btn-small:hover {
  background: rgba(124, 58, 237, 0.25);
}

.btn-fund {
  padding: 0.5rem 1rem;
  background: var(--blue-bg);
  border: 1px solid rgba(59, 130, 246, 0.3);
  border-radius: 6px;
  color: var(--blue);
  font-size: 0.8rem;
  font-weight: 600;
}

.btn-fund:hover:not(:disabled) {
  background: rgba(59, 130, 246, 0.25);
}

.btn-fund:disabled { opacity: 0.5; cursor: not-allowed; }

.btn-release {
  padding: 0.5rem 1rem;
  background: var(--green-bg);
  border: 1px solid rgba(16, 185, 129, 0.3);
  border-radius: 6px;
  color: var(--green);
  font-size: 0.8rem;
  font-weight: 600;
}

.btn-release:hover:not(:disabled) {
  background: rgba(16, 185, 129, 0.25);
}

.btn-release:disabled { opacity: 0.5; cursor: not-allowed; }

.btn-remove {
  width: 28px;
  height: 28px;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--red-bg);
  border: 1px solid rgba(239, 68, 68, 0.3);
  border-radius: 6px;
  color: var(--red);
  font-size: 0.8rem;
}

.btn-swap {
  margin-top: 1rem;
}

/* Button press feedback — instant tactile feel */
.btn-primary:active:not(:disabled) {
  transform: scale(0.97);
  filter: brightness(0.93);
}
.btn-secondary:active:not(:disabled),
.btn-fund:active:not(:disabled),
.btn-release:active:not(:disabled),
.btn-dispute:active:not(:disabled),
.btn-resolve:active:not(:disabled),
.btn-small:active:not(:disabled),
.btn-next-step:active:not(:disabled),
.btn-remove:active {
  transform: scale(0.96);
}
.disconnect-btn:active {
  transform: scale(0.95);
}
.connect-btn:active {
  transform: scale(0.97);
  filter: brightness(0.93);
}

/* ============================================
   Wallet
   ============================================ */

.connect-btn {
  padding: 0.625rem 1.25rem;
  background: linear-gradient(135deg, var(--accent), #a855f7);
  border: none;
  border-radius: var(--radius-sm);
  color: white;
  font-size: 0.9rem;
  font-weight: 600;
}

.connect-btn:hover {
  filter: brightness(1.1);
}

.wallet-info {
  display: flex;
  align-items: center;
  gap: 1rem;
  padding: 0.5rem 1rem;
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: var(--radius-sm);
}

.wallet-address {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  font-family: var(--font-mono);
  font-size: 0.85rem;
}

.dot {
  width: 8px;
  height: 8px;
  border-radius: 50%;
}

.dot.green {
  background: var(--green);
  box-shadow: 0 0 6px var(--green);
}

.wallet-balances {
  display: flex;
  gap: 0.75rem;
  font-size: 0.8rem;
  color: var(--text-muted);
}

.disconnect-btn {
  padding: 0.375rem 0.75rem;
  background: transparent;
  border: 1px solid var(--border);
  border-radius: 6px;
  color: var(--text-muted);
  font-size: 0.75rem;
}

.disconnect-btn:hover {
  border-color: var(--red);
  color: var(--red);
}

/* ============================================
   Wide layout (Dashboard tab)
   ============================================ */

.app-main-wide {
  max-width: 1200px;
}

/* ============================================
   Deal Dashboard — Master-Detail Layout
   ============================================ */

.deal-dashboard {
  animation: fadeIn 0.2s ease;
}

.dashboard-toolbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 0.75rem;
}

.dashboard-toolbar-left {
  display: flex;
  align-items: center;
  gap: 0.75rem;
}

.dashboard-toolbar-left h3 {
  margin-bottom: 0;
}

.deal-count-badge {
  font-size: 0.75rem;
  color: var(--text-muted);
  background: var(--bg-input);
  padding: 0.15rem 0.5rem;
  border-radius: 999px;
  border: 1px solid var(--border);
}

.dashboard-toolbar-right {
  display: flex;
  align-items: center;
  gap: 0.5rem;
}

.my-deals-toggle {
  display: flex;
  align-items: center;
  gap: 0.4rem;
  padding: 0.375rem 0.75rem;
  background: transparent;
  border: 1px solid var(--border);
  border-radius: 6px;
  color: var(--text-muted);
  font-size: 0.8rem;
  font-weight: 500;
}

.my-deals-toggle:hover {
  border-color: var(--accent);
  color: var(--text-secondary);
}

.my-deals-toggle.active {
  background: var(--accent-bg);
  border-color: rgba(124, 58, 237, 0.3);
  color: var(--accent-light);
}

.refresh-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 34px;
  height: 34px;
  background: transparent;
  border: 1px solid var(--border);
  border-radius: 6px;
  color: var(--text-muted);
}

.refresh-btn:hover:not(:disabled) {
  border-color: var(--accent);
  color: var(--accent-light);
}

.refresh-btn:disabled {
  opacity: 0.5;
  cursor: not-allowed;
}

/* Status filter tabs */
.status-filters {
  display: flex;
  gap: 0.25rem;
  margin-bottom: 0.75rem;
  overflow-x: auto;
  scrollbar-width: none;
}

.status-filters::-webkit-scrollbar {
  display: none;
}

.status-filter-btn {
  display: flex;
  align-items: center;
  gap: 0.35rem;
  padding: 0.375rem 0.75rem;
  background: transparent;
  border: 1px solid transparent;
  border-radius: 6px;
  color: var(--text-muted);
  font-size: 0.8rem;
  font-weight: 500;
  white-space: nowrap;
  transition: all 0.15s ease;
}

.status-filter-btn:hover {
  color: var(--text-secondary);
  background: var(--bg-card);
}

.status-filter-btn.active {
  background: var(--bg-card);
  border-color: var(--border);
  color: var(--text-primary);
}

.filter-count {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 18px;
  height: 18px;
  padding: 0 4px;
  border-radius: 999px;
  background: var(--bg-input);
  color: var(--text-muted);
  font-size: 0.65rem;
  font-weight: 700;
}

.status-filter-btn.active .filter-count {
  background: var(--accent-bg);
  color: var(--accent-light);
}

/* Main grid layout */
.dashboard-layout {
  display: grid;
  grid-template-columns: 320px 1fr;
  gap: 1rem;
}

/* Deal list panel */
.deal-list-panel {
  display: flex;
  flex-direction: column;
  gap: 0.375rem;
}

/* Deal cards */
.deal-card {
  display: flex;
  flex-direction: column;
  gap: 0.375rem;
  padding: 0.75rem;
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: var(--radius-sm);
  text-align: left;
  width: 100%;
  transition: all 0.15s ease;
}

.deal-card:hover {
  border-color: rgba(255, 255, 255, 0.12);
  background: var(--bg-card-hover);
}

.deal-card-selected {
  border-color: var(--accent) !important;
  background: var(--accent-bg) !important;
  box-shadow: 0 0 0 1px rgba(124, 58, 237, 0.2);
}

.deal-card-mine {
  border-left: 3px solid var(--accent);
}

.deal-card-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.deal-card-id {
  font-weight: 600;
  font-size: 0.85rem;
  color: var(--text-primary);
}

.deal-card-body {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.deal-card-amount {
  font-family: var(--font-mono);
  font-size: 0.8rem;
  color: var(--text-secondary);
}

.deal-card-progress {
  font-size: 0.75rem;
  color: var(--text-muted);
}

.deal-card-role {
  display: inline-block;
  align-self: flex-start;
  padding: 0.1rem 0.4rem;
  background: var(--accent-bg);
  color: var(--accent-light);
  border-radius: 4px;
  font-size: 0.65rem;
  font-weight: 700;
}

/* Deal list skeleton */
.deal-list-skeleton {
  display: flex;
  flex-direction: column;
  gap: 0.375rem;
}

.deal-card-skeleton {
  height: 72px;
  padding: 0.75rem;
  border-radius: var(--radius-sm);
  border: 1px solid var(--border);
}

/* Deal list empty state */
.deal-list-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 0.5rem;
  text-align: center;
  padding: 2rem 1rem;
  color: var(--text-muted);
}

.deal-list-empty h4 {
  color: var(--text-secondary);
  font-size: 0.95rem;
}

.deal-list-empty p {
  font-size: 0.8rem;
  max-width: 240px;
}

.deal-list-empty .btn-primary {
  margin-top: 0.5rem;
  width: auto;
  padding: 0.5rem 1.25rem;
  font-size: 0.85rem;
}

/* Detail empty state */
.detail-empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 0.75rem;
  text-align: center;
  padding: 4rem 2rem;
  color: var(--text-muted);
  height: 100%;
}

.detail-empty-state h4 {
  color: var(--text-secondary);
}

.detail-empty-state p {
  font-size: 0.85rem;
  max-width: 280px;
}

/* Mobile back button — hidden on desktop */
.mobile-back-btn {
  display: none;
  align-items: center;
  gap: 0.4rem;
  padding: 0.5rem 0;
  background: transparent;
  border: none;
  color: var(--accent-light);
  font-size: 0.85rem;
  font-weight: 500;
  margin-bottom: 0.75rem;
}

.mobile-back-btn:hover {
  color: var(--accent);
}

/* ============================================
   Deal Dashboard — Detail View (shared styles)
   ============================================ */

.deal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 1rem;
  flex-wrap: wrap;
}

.last-updated {
  font-size: 0.75rem;
  color: rgba(255, 255, 255, 0.35);
  width: 100%;
  text-align: right;
  margin-top: 0.25rem;
}

.balance-banner {
  background: rgba(99, 102, 241, 0.1);
  border: 1px solid rgba(99, 102, 241, 0.2);
  border-radius: 8px;
  padding: 0.75rem 1rem;
  margin-bottom: 1rem;
  font-size: 0.9rem;
  color: rgba(255, 255, 255, 0.8);
  text-align: center;
}

.balance-banner strong {
  color: #fff;
}

.deal-status {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  flex-wrap: wrap;
}

.deal-amount {
  font-size: 1.5rem;
  font-weight: 700;
  color: var(--green);
}

.status-badge {
  display: inline-block;
  padding: 0.25rem 0.75rem;
  border-radius: 999px;
  font-size: 0.75rem;
  font-weight: 600;
  color: white;
}

.status-badge.small {
  padding: 0.15rem 0.5rem;
  font-size: 0.7rem;
}

.participants {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1rem;
  margin-bottom: 1rem;
}

.participant {
  background: var(--bg-input);
  border-radius: var(--radius-sm);
  padding: 0.75rem;
}

.participant .label {
  display: block;
  font-size: 0.75rem;
  color: var(--text-muted);
  margin-bottom: 0.25rem;
}

.participant .value {
  font-family: var(--font-mono);
  font-size: 0.85rem;
}

.you-badge {
  display: inline-block;
  margin-left: 0.5rem;
  padding: 0.1rem 0.4rem;
  background: var(--accent-bg);
  color: var(--accent-light);
  border-radius: 4px;
  font-size: 0.65rem;
  font-weight: 700;
}

.deal-meta {
  display: flex;
  gap: 1.5rem;
  margin-bottom: 1.25rem;
  font-size: 0.85rem;
  color: var(--text-muted);
}

.milestones-list {
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
}

.milestone-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0.75rem 1rem;
  background: var(--bg-input);
  border-radius: var(--radius-sm);
  border: 1px solid var(--border);
}

.milestone-info {
  display: flex;
  align-items: center;
  gap: 0.75rem;
}

.milestone-name {
  font-weight: 500;
  font-size: 0.9rem;
}

.milestone-amount-display {
  font-family: var(--font-mono);
  font-size: 0.85rem;
  color: var(--text-secondary);
}

.milestone-actions {
  display: flex;
  gap: 0.5rem;
}

.released-check {
  color: var(--green);
  font-weight: 600;
  font-size: 0.85rem;
}

/* ============================================
   Create Deal Form
   ============================================ */

.milestones-section {
  margin: 1.25rem 0;
  padding: 1rem;
  background: var(--bg-input);
  border-radius: var(--radius-sm);
  border: 1px solid var(--border);
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 0.75rem;
}

.milestone-row {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  margin-bottom: 0.5rem;
}

.milestone-label {
  min-width: 100px;
  font-size: 0.85rem;
  color: var(--text-secondary);
}

.milestone-row input {
  width: 80px;
}

.milestone-amount {
  font-family: var(--font-mono);
  font-size: 0.85rem;
  color: var(--text-muted);
  min-width: 80px;
}

.split-preview {
  margin: 1rem 0;
  padding: 1rem;
  background: var(--accent-bg);
  border: 1px solid rgba(124, 58, 237, 0.2);
  border-radius: var(--radius-sm);
}

.split-preview h4 {
  margin-bottom: 0.75rem;
  color: var(--accent-light);
  font-size: 0.85rem;
}

.split-row {
  display: flex;
  justify-content: space-between;
  padding: 0.25rem 0;
  font-size: 0.85rem;
  color: var(--text-secondary);
}

.error-text {
  color: var(--red);
  font-size: 0.8rem;
}

/* ============================================
   Swap Widget
   ============================================ */

.fund-swap-container {
  display: flex;
  flex-direction: column;
  gap: 1rem;
}

.info-banner {
  padding: 0.75rem 1rem;
  background: var(--yellow-bg);
  border: 1px solid rgba(245, 158, 11, 0.3);
  border-radius: var(--radius-sm);
  color: var(--yellow);
  font-size: 0.85rem;
  margin-bottom: 1rem;
}

.swap-actions {
  display: flex;
  gap: 0.75rem;
  margin-top: 0.5rem;
}

.swap-actions .btn-secondary {
  width: auto;
  flex-shrink: 0;
}

.swap-actions .btn-primary {
  flex: 1;
}

.swap-box {
  margin: 1rem 0;
}

.swap-input-group {
  background: var(--bg-input);
  border: 1px solid var(--border);
  border-radius: var(--radius-sm);
  padding: 1rem;
}

.swap-input-group label {
  display: block;
  font-size: 0.75rem;
  color: var(--text-muted);
  margin-bottom: 0.5rem;
}

.swap-input-row {
  display: flex;
  align-items: center;
  gap: 0.75rem;
}

.swap-input-row input {
  flex: 1;
  background: transparent;
  border: none;
  color: var(--text-primary);
  font-size: 1.5rem;
  font-weight: 600;
  padding: 0;
}

.swap-input-row input:focus {
  outline: none;
  box-shadow: none;
}

.token-badge {
  padding: 0.375rem 0.75rem;
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: 999px;
  font-size: 0.85rem;
  font-weight: 600;
  color: var(--text-primary);
  white-space: nowrap;
}

.token-badge.usdc {
  background: var(--green-bg);
  border-color: rgba(16, 185, 129, 0.3);
  color: var(--green);
}

.swap-arrow {
  text-align: center;
  padding: 0.5rem;
  font-size: 1.25rem;
  color: var(--text-muted);
}

.swap-details {
  margin: 1rem 0;
  padding: 0.75rem 1rem;
  background: var(--bg-input);
  border-radius: var(--radius-sm);
}

.swap-detail-row {
  display: flex;
  justify-content: space-between;
  padding: 0.375rem 0;
  font-size: 0.8rem;
  color: var(--text-muted);
}

.swap-detail-row .warning {
  color: var(--yellow);
}

.swap-success {
  text-align: center;
  padding: 1.5rem;
}

.success-icon {
  width: 56px;
  height: 56px;
  background: var(--green-bg);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 1rem;
  font-size: 1.5rem;
  color: var(--green);
}

/* ============================================
   Reputation
   ============================================ */

.reputation-lookup {
  margin-bottom: 1rem;
}

.reputation-search {
  display: flex;
  gap: 0.5rem;
}

.reputation-search input {
  flex: 1;
}

.reputation-search-btn {
  width: auto !important;
  margin-top: 0 !important;
  white-space: nowrap;
}

.reputation-result {
  margin-top: 1.5rem;
}

.reputation-card {
  text-align: center;
  padding: 2rem;
  background: var(--bg-input);
  border-radius: var(--radius);
  border: 1px solid var(--border);
}

.activity-card {
  margin-bottom: 1rem;
}

.reputation-section-title {
  color: var(--accent-light);
  margin-bottom: 0.75rem;
  font-size: 0.85rem;
  text-transform: uppercase;
  letter-spacing: 0.5px;
}

/* Activity stats — role breakdown */
.activity-stats {
  display: flex;
  justify-content: center;
  gap: 1.5rem;
  margin-bottom: 1.25rem;
}

.activity-stat {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0.15rem;
}

.activity-stat-value {
  font-size: 1.5rem;
  font-weight: 700;
  color: var(--text-primary);
}

.activity-stat-label {
  font-size: 0.7rem;
  color: var(--text-muted);
  text-transform: uppercase;
  letter-spacing: 0.3px;
}

/* Activity progress bars */
.activity-progress {
  text-align: left;
  margin-bottom: 1rem;
}

.activity-progress-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 0.8rem;
  color: var(--text-secondary);
  margin-bottom: 0.25rem;
}

.activity-progress-value {
  font-weight: 600;
  font-family: var(--font-mono);
  color: var(--text-primary);
}

.highlight-active {
  color: var(--blue);
}

.activity-progress-bar {
  height: 6px;
  background: var(--bg-card);
  border-radius: 3px;
  overflow: hidden;
  margin-bottom: 0.75rem;
}

.activity-progress-fill {
  height: 100%;
  background: linear-gradient(90deg, var(--green), #34d399);
  border-radius: 3px;
  transition: width 0.6s ease;
  min-width: 2px;
}

.activity-progress-fill.completed {
  background: linear-gradient(90deg, var(--accent), #a78bfa);
}

.activity-volume {
  font-size: 0.8rem;
  color: var(--text-muted);
  padding-top: 0.75rem;
  border-top: 1px solid var(--border);
}

.activity-volume strong {
  color: var(--text-primary);
  font-family: var(--font-mono);
}

.reputation-score {
  margin-bottom: 0.75rem;
}

.score-number {
  font-size: 3.5rem;
  font-weight: 800;
  color: var(--accent-light);
  display: block;
  line-height: 1;
}

.score-label {
  font-size: 0.85rem;
  color: var(--text-muted);
}

.reputation-address {
  font-family: var(--font-mono);
  font-size: 0.85rem;
  color: var(--text-muted);
  margin-bottom: 1rem;
}

.reputation-badges {
  display: flex;
  gap: 0.5rem;
  justify-content: center;
  flex-wrap: wrap;
  margin-bottom: 1.25rem;
}

.badge {
  padding: 0.375rem 0.875rem;
  border-radius: 999px;
  font-size: 0.75rem;
  font-weight: 600;
}

.badge-verified {
  background: var(--green-bg);
  color: var(--green);
  border: 1px solid rgba(16, 185, 129, 0.3);
}

.badge-trusted {
  background: var(--blue-bg);
  color: var(--blue);
  border: 1px solid rgba(59, 130, 246, 0.3);
}

.badge-elite {
  background: var(--accent-bg);
  color: var(--accent-light);
  border: 1px solid rgba(124, 58, 237, 0.3);
}

.badge-new {
  background: var(--bg-card);
  color: var(--text-muted);
  border: 1px solid var(--border);
}

.reputation-info {
  margin-top: 1rem;
}

.reputation-info p {
  font-size: 0.8rem;
  color: var(--text-muted);
  margin-bottom: 0.75rem;
}

/* ============================================
   Messages
   ============================================ */

.error-message {
  padding: 0.75rem 1rem;
  background: var(--red-bg);
  border: 1px solid rgba(239, 68, 68, 0.3);
  border-radius: var(--radius-sm);
  color: var(--red);
  font-size: 0.85rem;
  margin: 0.75rem 0;
}

.success-banner {
  padding: 0.75rem 1rem;
  background: var(--green-bg);
  border: 1px solid rgba(16, 185, 129, 0.3);
  border-radius: var(--radius-sm);
  color: var(--green);
  font-size: 0.85rem;
  margin-bottom: 1rem;
}

.success-banner a {
  color: var(--green);
  text-decoration: underline;
  font-weight: 600;
}

.explorer-link {
  display: inline-block;
  margin: 0.5rem 0;
  font-size: 0.85rem;
  color: var(--accent-light);
}

.explorer-link:hover {
  text-decoration: underline;
}

/* ============================================
   Tab Step Labels
   ============================================ */

.tab-step {
  font-size: 0.6rem;
  text-transform: uppercase;
  letter-spacing: 0.5px;
  color: var(--text-muted);
  position: absolute;
  top: 4px;
  left: 50%;
  transform: translateX(-50%);
  opacity: 0.7;
}

.tab {
  position: relative;
  padding-top: 1.25rem;
}

.tab.active .tab-step {
  color: var(--accent-light);
  opacity: 1;
}

/* ============================================
   Demo Scenarios
   ============================================ */

.scenarios {
  margin-bottom: 1.25rem;
}

.scenarios-label {
  display: block;
  font-size: 0.8rem;
  font-weight: 600;
  color: var(--text-muted);
  text-transform: uppercase;
  letter-spacing: 0.5px;
  margin-bottom: 0.5rem;
}

.scenario-buttons {
  display: flex;
  gap: 0.5rem;
}

.btn-scenario {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0.25rem;
  padding: 0.75rem 0.5rem;
  background: var(--bg-input);
  border: 1px solid var(--border);
  border-radius: var(--radius-sm);
  color: var(--text-primary);
  font-size: 0.85rem;
  transition: all 0.2s;
}

.btn-scenario:hover {
  border-color: var(--accent);
  background: var(--accent-bg);
}

.scenario-name {
  font-weight: 600;
  font-size: 0.85rem;
}

.scenario-meta {
  font-size: 0.7rem;
  color: var(--text-muted);
}

/* ============================================
   Input Validation
   ============================================ */

.input-error {
  border-color: var(--red) !important;
}

.field-error {
  display: block;
  margin-top: 0.25rem;
  font-size: 0.75rem;
  color: var(--red);
}

.success-text {
  color: var(--green);
  font-weight: 600;
}

.text-muted {
  color: var(--text-muted);
  font-size: 0.85rem;
}

.highlight {
  color: var(--accent-light);
  font-weight: 700;
  font-size: 1.1rem;
}

/* ============================================
   Success Actions
   ============================================ */

.success-actions {
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
  margin-top: 1rem;
}

.success-actions .btn-primary {
  margin-top: 0;
}

/* ============================================
   Split Preview — enhanced
   ============================================ */

.split-value {
  font-weight: 600;
  color: var(--text-primary);
}

.split-total {
  border-top: 1px solid rgba(124, 58, 237, 0.2);
  margin-top: 0.25rem;
  padding-top: 0.5rem;
  font-weight: 600;
}

/* ============================================
   3-Way Split Visualization
   ============================================ */

.split-visualization {
  background: var(--bg-input);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  padding: 1.5rem;
  margin-bottom: 1rem;
  animation: fadeIn 0.3s ease;
}

.split-visualization h4 {
  color: var(--green);
  margin-bottom: 0.25rem;
}

.split-subtitle {
  color: var(--text-muted);
  font-size: 0.8rem;
  margin-bottom: 1rem;
}

.split-bar {
  display: flex;
  height: 32px;
  border-radius: 6px;
  overflow: hidden;
  margin-bottom: 1rem;
  gap: 2px;
}

.split-segment {
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 0.7rem;
  font-weight: 700;
  color: white;
  min-width: 30px;
}

.split-segment.provider {
  background: linear-gradient(135deg, #10b981, #059669);
}

.split-segment.connector {
  background: linear-gradient(135deg, #3b82f6, #2563eb);
}

.split-segment.protocol {
  background: linear-gradient(135deg, #7c3aed, #6d28d9);
}

.split-legend {
  display: flex;
  flex-wrap: wrap;
  gap: 1rem;
  margin-bottom: 0.75rem;
}

.split-legend-item {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  font-size: 0.85rem;
  color: var(--text-secondary);
}

.legend-dot {
  width: 10px;
  height: 10px;
  border-radius: 3px;
}

.legend-dot.provider { background: #10b981; }
.legend-dot.connector { background: #3b82f6; }
.legend-dot.protocol { background: #7c3aed; }

/* ============================================
   Deal ID label
   ============================================ */

.deal-id-label {
  font-size: 0.8rem;
  color: var(--text-muted);
  margin-left: 0.75rem;
  font-family: var(--font-mono);
}

/* ============================================
   Fund / Swap — next step CTA
   ============================================ */

.fund-success,
.fund-error {
  margin-top: 12px;
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 0.75rem;
}

.btn-next-step {
  padding: 0.375rem 0.75rem;
  background: rgba(255, 255, 255, 0.15);
  border: 1px solid rgba(255, 255, 255, 0.2);
  border-radius: 6px;
  color: inherit;
  font-size: 0.8rem;
  font-weight: 600;
  white-space: nowrap;
}

.btn-next-step:hover {
  background: rgba(255, 255, 255, 0.25);
}

/* ============================================
   Connect Prompt — animations
   ============================================ */

.connect-prompt-icon {
  animation: bounceIn 0.6s ease;
}

.connect-prompt-icon svg {
  color: var(--accent);
}

.feature.animate-in {
  opacity: 0;
  animation: slideUp 0.4s ease forwards;
}

.feature.animate-in:nth-child(1) { animation-delay: 0.1s; }
.feature.animate-in:nth-child(2) { animation-delay: 0.2s; }
.feature.animate-in:nth-child(3) { animation-delay: 0.3s; }
.feature.animate-in:nth-child(4) { animation-delay: 0.4s; }

/* ============================================
   Button with icon
   ============================================ */

.btn-icon {
  display: inline-flex;
  vertical-align: middle;
  margin-right: 0.5rem;
}

.btn-primary:hover .btn-icon {
  animation: pulse 0.8s ease infinite;
}

/* ============================================
   Success animations
   ============================================ */

.success-card {
  animation: scaleIn 0.4s ease;
}

.success-card .success-icon {
  animation: bounceIn 0.6s ease;
}

.success-banner {
  animation: slideUp 0.3s ease;
}

.split-visualization {
  animation: slideUp 0.4s ease;
}

/* ============================================
   Green dot pulse
   ============================================ */

.dot.green {
  animation: dotPulse 2s ease-in-out infinite;
}

/* ============================================
   Loading spinner
   ============================================ */

button:disabled {
  position: relative;
}

.btn-primary:disabled:not([class*="btn-large"]) {
  background: linear-gradient(
    90deg,
    var(--accent) 0%,
    #a855f7 50%,
    var(--accent) 100%
  );
  background-size: 200% 100%;
  animation: shimmer 1.5s ease-in-out infinite;
}

/* ============================================
   Card entrance
   ============================================ */

.card {
  animation: fadeIn 0.3s ease;
}

/* ============================================
   Reputation badges entrance
   ============================================ */

.reputation-card {
  animation: scaleIn 0.4s ease;
}

.badge {
  animation: fadeIn 0.3s ease;
}

.badge:nth-child(1) { animation-delay: 0.05s; }
.badge:nth-child(2) { animation-delay: 0.15s; }
.badge:nth-child(3) { animation-delay: 0.25s; }

/* ============================================
   Score number entrance
   ============================================ */

.score-number {
  animation: bounceIn 0.5s ease;
}

/* ============================================
   Scenario button active feedback
   ============================================ */

.btn-scenario:active {
  transform: scale(0.97);
}

/* ============================================
   Milestone item hover
   ============================================ */

.milestone-item {
  transition: border-color 0.2s, background 0.2s;
}

.milestone-item:hover {
  border-color: var(--accent);
  background: var(--bg-card-hover);
}

/* ============================================
   Production Parity Banner
   ============================================ */

.parity-banner {
  display: flex;
  align-items: flex-start;
  gap: 1rem;
  padding: 1rem 1.25rem;
  background: var(--accent-bg);
  border: 1px solid rgba(124, 58, 237, 0.25);
  border-radius: var(--radius-sm);
  margin-bottom: 1.5rem;
  animation: slideUp 0.3s ease;
}

.parity-banner-content {
  flex: 1;
}

.parity-banner-content strong {
  display: block;
  color: var(--accent-light);
  font-size: 0.9rem;
  margin-bottom: 0.25rem;
}

.parity-banner-content p {
  font-size: 0.8rem;
  color: var(--text-secondary);
  margin-bottom: 0.5rem;
}

.parity-banner-content ul {
  list-style: none;
  padding: 0;
}

.parity-banner-content li {
  font-size: 0.8rem;
  color: var(--text-secondary);
  padding: 0.15rem 0;
}

.parity-banner-content li::before {
  content: '✓ ';
  color: var(--green);
  font-weight: 600;
}

.parity-banner-dismiss {
  background: transparent;
  border: none;
  color: var(--text-muted);
  font-size: 1.25rem;
  padding: 0;
  line-height: 1;
  flex-shrink: 0;
}

.parity-banner-dismiss:hover {
  color: var(--text-primary);
}

/* ============================================
   Confirmation Modal
   ============================================ */

.modal-overlay {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.7);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 200;
  animation: fadeIn 0.2s ease;
  padding: 1rem;
}

.modal-card {
  background: rgba(22, 22, 31, 0.85);
  border: 1px solid rgba(255, 255, 255, 0.08);
  border-radius: var(--radius);
  padding: 1.5rem;
  max-width: 480px;
  width: 100%;
  animation: scaleIn 0.2s ease;
  -webkit-backdrop-filter: blur(20px);
  backdrop-filter: blur(20px);
}

.modal-card h3 {
  margin-bottom: 0.5rem;
}

.modal-subtitle {
  font-size: 0.85rem;
  color: var(--text-secondary);
  margin-bottom: 1rem;
  line-height: 1.5;
}

.modal-split-preview {
  background: var(--bg-input);
  border-radius: var(--radius-sm);
  padding: 0.75rem 1rem;
  margin-bottom: 1rem;
}

.modal-split-row {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  padding: 0.35rem 0;
  font-size: 0.85rem;
  color: var(--text-secondary);
}

.modal-split-amount {
  margin-left: auto;
  font-family: var(--font-mono);
  font-weight: 600;
  color: var(--text-primary);
}

.modal-actions {
  display: flex;
  gap: 0.75rem;
  margin-top: 1rem;
}

.modal-actions .btn-secondary {
  flex: 1;
}

.modal-actions .btn-release,
.modal-actions .btn-dispute,
.modal-actions .btn-primary {
  flex: 1;
  width: auto;
  margin-top: 0;
}

/* ============================================
   Milestone Timeline
   ============================================ */

.milestone-timeline {
  display: flex;
  flex-direction: column;
  gap: 0;
}

.timeline-item {
  display: flex;
  gap: 1rem;
  min-height: 70px;
}

.timeline-track {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 36px;
  flex-shrink: 0;
}

.timeline-node {
  width: 32px;
  height: 32px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 0.75rem;
  font-weight: 700;
  color: white;
  flex-shrink: 0;
  z-index: 1;
}

.timeline-node-pending {
  background: var(--bg-input);
  border: 2px solid var(--border);
  color: var(--text-muted);
}

.timeline-node-funded {
  background: var(--blue-bg);
  border: 2px solid var(--blue);
  color: var(--blue);
}

.timeline-node-released {
  background: var(--green);
  border: 2px solid var(--green);
  color: white;
}

.timeline-node-disputed {
  background: var(--red-bg);
  border: 2px solid var(--red);
  color: var(--red);
}

.timeline-node-refunded {
  background: var(--yellow-bg);
  border: 2px solid var(--yellow);
  color: var(--yellow);
}

.timeline-line {
  width: 2px;
  flex: 1;
  min-height: 16px;
  background: var(--border);
  border-left: 2px dashed var(--border);
  margin: 2px 0;
}

.timeline-line-done {
  background: var(--green);
  border-left: 2px solid var(--green);
}

.timeline-content {
  flex: 1;
  padding-bottom: 1rem;
}

.timeline-content .milestone-info {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  flex-wrap: wrap;
  margin-bottom: 0.5rem;
}

.timeline-content .milestone-actions {
  display: flex;
  gap: 0.5rem;
  flex-wrap: wrap;
}

/* ============================================
   Status Badge Variants (class-based)
   ============================================ */

.status-pending { background: var(--yellow); }
.status-funded { background: var(--blue); }
.status-released { background: var(--green); }
.status-disputed { background: var(--red); }
.status-refunded { background: var(--yellow); }

/* ============================================
   Dispute & Resolve Buttons
   ============================================ */

.btn-dispute {
  padding: 0.5rem 1rem;
  background: var(--red-bg);
  border: 1px solid rgba(239, 68, 68, 0.3);
  border-radius: 6px;
  color: var(--red);
  font-size: 0.8rem;
  font-weight: 600;
}

.btn-dispute:hover:not(:disabled) {
  background: rgba(239, 68, 68, 0.25);
}

.btn-dispute:disabled { opacity: 0.5; cursor: not-allowed; }

.btn-resolve {
  padding: 0.5rem 1rem;
  background: var(--yellow-bg);
  border: 1px solid rgba(245, 158, 11, 0.3);
  border-radius: 6px;
  color: var(--yellow);
  font-size: 0.8rem;
  font-weight: 600;
}

.btn-resolve:hover:not(:disabled) {
  background: rgba(245, 158, 11, 0.25);
}

.btn-resolve:disabled { opacity: 0.5; cursor: not-allowed; }

/* ============================================
   Resolve Slider
   ============================================ */

.resolve-slider {
  margin: 1rem 0;
}

.resolve-slider input[type="range"] {
  width: 100%;
  height: 6px;
  -webkit-appearance: none;
  appearance: none;
  background: linear-gradient(to right, var(--blue), var(--red));
  border-radius: 3px;
  outline: none;
  border: none;
  padding: 0;
}

.resolve-slider input[type="range"]::-webkit-slider-thumb {
  -webkit-appearance: none;
  width: 20px;
  height: 20px;
  border-radius: 50%;
  background: white;
  border: 2px solid var(--accent);
  cursor: pointer;
}

.resolve-preview {
  display: flex;
  justify-content: space-between;
  margin-top: 0.75rem;
  font-size: 0.8rem;
  color: var(--text-secondary);
}

/* ============================================
   Copy-to-Clipboard
   ============================================ */

.copyable {
  cursor: pointer;
  display: inline-flex;
  align-items: center;
  gap: 0.35rem;
  transition: color 0.2s;
}

.copyable:hover {
  color: var(--accent-light);
}

.copy-icon {
  display: inline-flex;
  opacity: 0.4;
  transition: opacity 0.2s;
}

.copyable:hover .copy-icon {
  opacity: 1;
}

.copied-feedback {
  font-size: 0.7rem;
  color: var(--green);
  font-weight: 600;
  animation: fadeIn 0.2s ease;
}

.inline-copy {
  margin-left: 0.5rem;
}

/* ============================================
   Empty State
   ============================================ */

.empty-state {
  text-align: center;
  padding: 3rem 2rem;
  color: var(--text-muted);
}

.empty-state-icon {
  margin-bottom: 1rem;
  opacity: 0.4;
}

.empty-state h4 {
  color: var(--text-secondary);
  margin-bottom: 0.5rem;
}

.empty-state p {
  font-size: 0.85rem;
  max-width: 360px;
  margin: 0 auto;
}

/* ============================================
   Escrow Protection Badge
   ============================================ */

.escrow-badge {
  display: inline-flex;
  align-items: center;
  gap: 0.35rem;
  padding: 0.25rem 0.75rem;
  background: var(--green-bg);
  border: 1px solid rgba(16, 185, 129, 0.3);
  border-radius: 999px;
  color: var(--green);
  font-size: 0.7rem;
  font-weight: 600;
  margin-left: 0.75rem;
}

/* ============================================
   Completion Banner
   ============================================ */

.completion-banner {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  padding: 0.75rem 1rem;
  background: var(--green-bg);
  border: 1px solid rgba(16, 185, 129, 0.3);
  border-radius: var(--radius-sm);
  color: var(--green);
  font-size: 0.85rem;
  margin-bottom: 1rem;
  animation: slideUp 0.3s ease;
}

.completion-icon {
  font-size: 1.25rem;
  font-weight: 700;
}

/* ============================================
   Deal Review / Summary Step
   ============================================ */

.review-card {
  border-color: rgba(124, 58, 237, 0.3);
  background: rgba(22, 22, 31, 0.8);
  -webkit-backdrop-filter: blur(12px);
  backdrop-filter: blur(12px);
}

.review-section {
  margin-bottom: 1rem;
  padding: 0.75rem 1rem;
  background: var(--bg-input);
  border-radius: var(--radius-sm);
  border: 1px solid var(--border);
}

.review-section h4 {
  color: var(--accent-light);
  font-size: 0.8rem;
  text-transform: uppercase;
  letter-spacing: 0.5px;
  margin-bottom: 0.5rem;
}

.review-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0.3rem 0;
  font-size: 0.85rem;
}

.review-label {
  color: var(--text-secondary);
}

.review-value {
  color: var(--text-primary);
  font-weight: 500;
}

.review-value.mono {
  font-family: var(--font-mono);
  font-size: 0.8rem;
}

.review-actions {
  display: flex;
  gap: 0.75rem;
  margin-top: 1rem;
}

.review-actions .btn-secondary {
  flex: 0 0 auto;
  width: auto;
  min-width: 100px;
}

.review-actions .btn-primary {
  flex: 1;
  margin-top: 0;
}

/* ============================================
   Loading Skeletons
   ============================================ */

@keyframes shimmer {
  0% { background-position: -400px 0; }
  100% { background-position: 400px 0; }
}

.skeleton {
  background: linear-gradient(90deg, var(--bg-input) 25%, rgba(255,255,255,0.06) 50%, var(--bg-input) 75%);
  background-size: 800px 100%;
  animation: shimmer 1.5s infinite linear;
  border-radius: var(--radius-sm);
}

.skeleton-line {
  height: 0.875rem;
  margin-bottom: 0.5rem;
  border-radius: 4px;
}

.skeleton-line.short { width: 40%; }
.skeleton-line.medium { width: 65%; }
.skeleton-line.long { width: 85%; }

.skeleton-card {
  padding: 1rem;
  border-radius: var(--radius-sm);
  border: 1px solid var(--border);
  margin-bottom: 0.75rem;
}

.skeleton-circle {
  width: 32px;
  height: 32px;
  border-radius: 50%;
  flex-shrink: 0;
}

.skeleton-row {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  margin-bottom: 0.75rem;
}

.skeleton-block {
  flex: 1;
}

.skeleton-centered {
  justify-content: center;
}

.skeleton-circle-lg {
  width: 56px;
  height: 56px;
}

.skeleton-centered-line {
  margin: 0.75rem auto 0;
}

/* ============================================
   Toast Notifications
   ============================================ */

.toast-container {
  position: fixed;
  top: 1rem;
  right: 1rem;
  z-index: 9999;
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
  pointer-events: none;
}

.toast {
  display: flex;
  align-items: center;
  gap: 0.625rem;
  padding: 0.75rem 1.125rem;
  border-radius: var(--radius-sm);
  background: rgba(22, 22, 31, 0.92);
  border: 1px solid rgba(255, 255, 255, 0.08);
  -webkit-backdrop-filter: blur(16px);
  backdrop-filter: blur(16px);
  color: var(--text-primary);
  font-size: 0.875rem;
  box-shadow: 0 8px 32px rgba(0, 0, 0, 0.4);
  pointer-events: auto;
  cursor: pointer;
  animation: toastIn 0.3s ease forwards;
  max-width: 380px;
}

.toast-exit {
  animation: toastOut 0.3s ease forwards;
}

.toast-icon {
  flex-shrink: 0;
  width: 20px;
  height: 20px;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  font-size: 0.7rem;
  font-weight: 700;
}

.toast-success { border-color: rgba(16, 185, 129, 0.3); }
.toast-success .toast-icon { background: rgba(16, 185, 129, 0.2); color: var(--green); }
.toast-error { border-color: rgba(239, 68, 68, 0.3); }
.toast-error .toast-icon { background: rgba(239, 68, 68, 0.2); color: var(--red); }
.toast-info { border-color: rgba(59, 130, 246, 0.3); }
.toast-info .toast-icon { background: rgba(59, 130, 246, 0.2); color: var(--blue); }

.toast-message {
  flex: 1;
  line-height: 1.35;
}

@keyframes toastIn {
  from { opacity: 0; transform: translateX(100%) scale(0.95); }
  to { opacity: 1; transform: translateX(0) scale(1); }
}

@keyframes toastOut {
  from { opacity: 1; transform: translateX(0) scale(1); }
  to { opacity: 0; transform: translateX(100%) scale(0.95); }
}

/* ============================================
   A7: Success Celebration Animation
   ============================================ */

.success-icon-animated {
  width: 64px;
  height: 64px;
  margin: 0 auto 1rem;
  position: relative;
}

.success-icon-animated svg {
  width: 64px;
  height: 64px;
}

.success-icon-animated .check-circle {
  stroke: var(--green);
  stroke-width: 2;
  fill: none;
  stroke-dasharray: 166;
  stroke-dashoffset: 166;
  animation: checkCircleDraw 0.6s ease forwards;
}

.success-icon-animated .check-mark {
  stroke: var(--green);
  stroke-width: 3;
  fill: none;
  stroke-linecap: round;
  stroke-linejoin: round;
  stroke-dasharray: 48;
  stroke-dashoffset: 48;
  animation: checkMarkDraw 0.4s 0.4s ease forwards;
}

.success-icon-animated::after {
  content: '';
  position: absolute;
  inset: -8px;
  border-radius: 50%;
  background: rgba(16, 185, 129, 0.15);
  animation: successPulse 1s 0.6s ease-out forwards;
  opacity: 0;
}

@keyframes checkCircleDraw {
  to { stroke-dashoffset: 0; }
}

@keyframes checkMarkDraw {
  to { stroke-dashoffset: 0; }
}

@keyframes successPulse {
  0% { opacity: 0.6; transform: scale(0.8); }
  100% { opacity: 0; transform: scale(1.6); }
}

.success-card {
  text-align: center;
  border-color: rgba(16, 185, 129, 0.3);
  box-shadow: 0 0 30px rgba(16, 185, 129, 0.08);
}

/* ============================================
   A8: Error Recovery with Retry
   ============================================ */

.error-message {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 0.75rem;
  flex-wrap: wrap;
}

.btn-retry {
  padding: 0.375rem 0.875rem;
  background: rgba(239, 68, 68, 0.15);
  border: 1px solid rgba(239, 68, 68, 0.3);
  border-radius: var(--radius-sm);
  color: var(--red);
  font-size: 0.8rem;
  cursor: pointer;
  white-space: nowrap;
  transition: background 0.15s;
}

.btn-retry:hover {
  background: rgba(239, 68, 68, 0.25);
}

.btn-retry:active {
  transform: scale(0.96);
}

/* ============================================
   A5: Transaction Progress Steps
   ============================================ */

.tx-progress {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 0;
  margin: 1rem 0;
}

.tx-step {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  padding: 0.5rem 0.75rem;
  font-size: 0.8rem;
  color: var(--text-muted);
  opacity: 0.5;
  transition: all 0.3s ease;
}

.tx-step.active {
  opacity: 1;
  color: var(--accent);
}

.tx-step.done {
  opacity: 1;
  color: var(--green);
}

.tx-spinner {
  width: 14px;
  height: 14px;
  border: 2px solid rgba(124, 58, 237, 0.2);
  border-top-color: var(--accent);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

.tx-step.done .tx-spinner {
  border: none;
  animation: none;
}

.tx-step.done .tx-spinner::after {
  content: '✓';
  font-size: 0.75rem;
  color: var(--green);
}

.tx-step-divider {
  width: 24px;
  height: 1px;
  background: var(--border);
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

/* ============================================
   B1: Staggered List Animations
   ============================================ */

@keyframes staggerIn {
  from { opacity: 0; transform: translateY(8px); }
  to { opacity: 1; transform: translateY(0); }
}

.stagger-item {
  animation: staggerIn 0.3s ease forwards;
  opacity: 0;
}

.stagger-item:nth-child(1) { animation-delay: 0s; }
.stagger-item:nth-child(2) { animation-delay: 0.05s; }
.stagger-item:nth-child(3) { animation-delay: 0.1s; }
.stagger-item:nth-child(4) { animation-delay: 0.15s; }
.stagger-item:nth-child(5) { animation-delay: 0.2s; }
.stagger-item:nth-child(6) { animation-delay: 0.25s; }
.stagger-item:nth-child(7) { animation-delay: 0.3s; }
.stagger-item:nth-child(8) { animation-delay: 0.35s; }

/* ============================================
   B2: Hover State Improvements
   ============================================ */

.card {
  transition: border-color 0.2s ease, box-shadow 0.2s ease;
}

.card:hover {
  border-color: rgba(255, 255, 255, 0.1);
}

.participant {
  transition: transform 0.15s ease, border-color 0.15s ease;
}

.participant:hover {
  transform: translateY(-1px);
  border-color: rgba(255, 255, 255, 0.12);
}

.feature {
  transition: transform 0.15s ease, background 0.15s ease;
}

.feature:hover {
  transform: translateY(-2px);
  background: rgba(124, 58, 237, 0.08);
}

.wallet-info {
  transition: background 0.15s ease;
}

.wallet-info:hover {
  background: rgba(255, 255, 255, 0.04);
}

/* ============================================
   B5: Tab Active Indicator + Transitions
   ============================================ */

.tab {
  position: relative;
}

.tab.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 15%;
  right: 15%;
  height: 2px;
  background: var(--accent);
  border-radius: 2px;
  animation: tabIndicator 0.25s ease;
}

@keyframes tabIndicator {
  from { transform: scaleX(0); }
  to { transform: scaleX(1); }
}

.tab-content {
  animation: tabFadeIn 0.2s ease;
}

@keyframes tabFadeIn {
  from { opacity: 0; transform: translateY(4px); }
  to { opacity: 1; transform: translateY(0); }
}

/* ============================================
   B3: Form Field Hints
   ============================================ */

.field-hint {
  display: block;
  font-size: 0.75rem;
  color: var(--text-muted);
  margin-top: 0.25rem;
  line-height: 1.4;
}

/* ============================================
   B4: Address Tooltip on Hover
   ============================================ */

.copyable {
  position: relative;
}

.copyable::before {
  content: attr(title);
  position: absolute;
  bottom: calc(100% + 6px);
  left: 50%;
  transform: translateX(-50%) scale(0.95);
  padding: 0.375rem 0.625rem;
  background: rgba(10, 10, 15, 0.95);
  border: 1px solid rgba(255, 255, 255, 0.1);
  border-radius: 6px;
  color: var(--text-primary);
  font-size: 0.7rem;
  font-family: var(--font-mono);
  white-space: nowrap;
  pointer-events: none;
  opacity: 0;
  transition: opacity 0.15s ease, transform 0.15s ease;
  z-index: 100;
}

.copyable:hover::before {
  opacity: 1;
  transform: translateX(-50%) scale(1);
}

/* ============================================
   C1: Scroll-Reactive Header
   ============================================ */

.app-header {
  transition: background 0.2s ease, box-shadow 0.2s ease;
}

.header-scrolled {
  background: rgba(12, 12, 18, 0.92) !important;
  box-shadow: 0 4px 20px rgba(0, 0, 0, 0.3);
}

/* ============================================
   C3: Split Bar Animated Fill
   ============================================ */

.split-segment {
  animation: barGrow 0.5s ease forwards;
  transform-origin: left;
}

@keyframes barGrow {
  from { transform: scaleX(0); }
  to { transform: scaleX(1); }
}

.split-segment.connector { animation-delay: 0.1s; }
.split-segment.protocol { animation-delay: 0.2s; }

/* ============================================
   Responsive
   ============================================ */

@media (max-width: 768px) {
  .app-header {
    flex-direction: column;
    gap: 0.75rem;
    padding: 0.75rem 1rem;
  }

  .header-left {
    width: 100%;
  }

  .header-right {
    width: 100%;
    justify-content: space-between;
  }

  .app-main {
    padding: 0.75rem;
  }

  .tabs {
    flex-wrap: nowrap;
    overflow-x: auto;
    gap: 0.15rem;
    padding: 0.2rem;
  }

  .tabs::-webkit-scrollbar {
    display: none;
  }

  .tab {
    flex: 0 0 auto;
    min-width: 0;
    padding: 0.6rem 0.75rem;
    padding-top: 1.1rem;
    font-size: 0.8rem;
    gap: 0.35rem;
  }

  .tab-label {
    font-size: 0.75rem;
    white-space: nowrap;
  }

  .tab-icon svg {
    width: 14px;
    height: 14px;
  }

  .tab-step {
    font-size: 0.5rem;
  }

  .card {
    padding: 1rem;
  }

  .form-row {
    grid-template-columns: 1fr;
  }

  .participants {
    grid-template-columns: 1fr;
  }

  .connect-features {
    grid-template-columns: 1fr;
  }

  .connect-prompt {
    padding: 2rem 1rem;
  }

  .connect-prompt h2 {
    font-size: 1.5rem;
  }

  .scenario-buttons {
    flex-direction: column;
  }

  .btn-scenario {
    flex-direction: row;
    justify-content: space-between;
    align-items: center;
    padding: 0.75rem 1rem;
  }

  .swap-actions {
    flex-direction: column;
  }

  .swap-actions .btn-secondary,
  .swap-actions .btn-primary {
    width: 100%;
  }

  .wallet-info {
    flex-wrap: wrap;
    gap: 0.5rem;
    font-size: 0.8rem;
    padding: 0.375rem 0.75rem;
  }

  .wallet-balances {
    font-size: 0.7rem;
  }

  /* Dashboard master-detail → stacked on mobile */
  .dashboard-layout {
    grid-template-columns: 1fr;
  }

  .deal-list-panel,
  .deal-detail-panel {
    max-height: none;
  }

  .mobile-hidden {
    display: none !important;
  }

  .mobile-back-btn {
    display: flex;
  }

  .dashboard-toolbar {
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .status-filters {
    flex-wrap: nowrap;
  }

  .deal-header {
    flex-direction: column;
    align-items: flex-start;
    gap: 0.5rem;
  }

  .deal-meta {
    flex-direction: column;
    gap: 0.25rem;
  }

  .milestone-item {
    flex-direction: column;
    align-items: flex-start;
    gap: 0.5rem;
  }

  .milestone-actions {
    width: 100%;
  }

  .milestone-actions button {
    flex: 1;
  }

  .split-legend {
    flex-direction: column;
    gap: 0.5rem;
  }

  .timeline-content .milestone-info {
    gap: 0.5rem;
  }

  .timeline-content .milestone-actions {
    width: 100%;
  }

  .timeline-content .milestone-actions button {
    flex: 1;
  }

  .modal-card {
    margin: 0.5rem;
  }

  .modal-actions {
    flex-direction: column;
  }

  .resolve-preview {
    flex-direction: column;
    gap: 0.25rem;
  }

  .review-actions {
    flex-direction: column;
  }

  .review-actions .btn-secondary {
    width: 100%;
  }

  .deal-status {
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .escrow-badge {
    margin-left: 0;
  }

  .app-footer {
    padding: 1rem;
  }

  .footer-top {
    flex-direction: column;
    text-align: center;
    gap: 0.75rem;
  }

  .footer-brand {
    flex-direction: column;
    gap: 0.5rem;
  }

  .footer-brand div {
    text-align: center;
  }

  .footer-middle {
    flex-direction: column;
    gap: 1.5rem;
  }

  .footer-links-group {
    align-items: center;
  }

  .footer-bottom {
    flex-direction: column;
    gap: 0.5rem;
    text-align: center;
  }
}

@media (max-width: 480px) {
  .tabs {
    margin-bottom: 1rem;
  }

  .tab {
    padding: 0.5rem 0.5rem;
    padding-top: 1rem;
  }

  .tab-label {
    font-size: 0.65rem;
  }

  .logo-title {
    font-size: 0.95rem;
  }

  .logo-subtitle {
    font-size: 0.6rem;
  }

  .logo-img {
    width: 32px;
    height: 32px;
  }

  .deal-amount {
    font-size: 1.25rem;
  }

  h3 {
    font-size: 1.1rem;
  }

  .milestone-row {
    flex-wrap: wrap;
  }

  .milestone-label {
    min-width: 80px;
  }

  .milestone-name-input {
    min-width: 0;
    flex: 1;
  }

  .financial-grid {
    grid-template-columns: 1fr !important;
  }

  .activity-split {
    font-size: 0.7rem;
  }
}

/* ============================================
   CreateDeal — Deal Metadata Fields
   ============================================ */

.milestone-name-input {
  flex: 1;
  min-width: 120px;
  font-size: 0.85rem;
}

.milestone-pct-input {
  width: 80px !important;
  flex: none !important;
}

.milestone-row {
  flex-wrap: wrap;
}

textarea {
  width: 100%;
  min-height: 60px;
  resize: vertical;
  background: var(--bg-input);
  border: 1px solid var(--border);
  border-radius: var(--radius-sm);
  color: var(--text-primary);
  font-family: var(--font-sans);
  font-size: 0.9rem;
  padding: 0.75rem;
  transition: border-color 0.2s;
}

textarea:focus {
  outline: none;
  border-color: var(--border-focus);
}

.review-description {
  color: var(--text-secondary);
  font-size: 0.85rem;
  margin-top: 0.25rem;
}

/* ============================================
   DealDashboard — Deal Metadata Display
   ============================================ */

.deal-description {
  color: var(--text-secondary);
  font-size: 0.85rem;
  margin-top: 0.5rem;
  line-height: 1.4;
}

.deal-created-at {
  color: var(--text-muted);
  font-size: 0.75rem;
  margin-top: 0.25rem;
}

/* ============================================
   Financial Summary
   ============================================ */

.financial-summary {
  margin-top: 1.5rem;
  padding: 1rem;
  background: var(--bg-secondary);
  border: 1px solid var(--border);
  border-radius: var(--radius);
}

.financial-summary h4 {
  margin-bottom: 0.75rem;
  font-size: 0.9rem;
  color: var(--text-primary);
}

.financial-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 0.75rem;
}

.financial-item {
  display: flex;
  flex-direction: column;
  gap: 0.25rem;
}

.financial-label {
  font-size: 0.7rem;
  color: var(--text-muted);
  text-transform: uppercase;
  letter-spacing: 0.05em;
}

.financial-value {
  font-family: var(--font-mono);
  font-size: 0.9rem;
  color: var(--text-primary);
  font-weight: 600;
}

.financial-value.highlight-escrow {
  color: var(--yellow);
}

/* ============================================
   Activity Log / Feed
   ============================================ */

.activity-feed {
  margin-top: 1.5rem;
  padding: 1rem;
  background: var(--bg-secondary);
  border: 1px solid var(--border);
  border-radius: var(--radius);
}

.activity-feed h4 {
  margin-bottom: 0.75rem;
  font-size: 0.9rem;
  color: var(--text-primary);
}

.activity-list {
  display: flex;
  flex-direction: column;
  gap: 0;
}

.activity-item {
  display: flex;
  align-items: flex-start;
  gap: 0.75rem;
  padding: 0.75rem 0;
  border-bottom: 1px solid rgba(255, 255, 255, 0.05);
}

.activity-item:last-child {
  border-bottom: none;
}

.activity-dot {
  width: 8px;
  height: 8px;
  border-radius: 50%;
  margin-top: 6px;
  flex-shrink: 0;
  background: var(--text-muted);
}

.activity-funded .activity-dot { background: var(--blue); }
.activity-released .activity-dot { background: var(--green); }
.activity-disputed .activity-dot { background: var(--red); }
.activity-resolved .activity-dot { background: var(--yellow); }

.activity-content {
  flex: 1;
  min-width: 0;
}

.activity-header {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  flex-wrap: wrap;
}

.activity-label {
  font-size: 0.85rem;
  font-weight: 600;
  color: var(--text-primary);
}

.activity-milestone {
  font-size: 0.75rem;
  color: var(--text-muted);
  padding: 0.1rem 0.4rem;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 4px;
}

.activity-time {
  font-size: 0.75rem;
  color: var(--text-muted);
  margin-top: 0.15rem;
}

.activity-split {
  font-size: 0.75rem;
  color: var(--text-secondary);
  font-family: var(--font-mono);
  margin-top: 0.25rem;
}

.activity-tx-link {
  font-size: 0.75rem;
  color: var(--accent-light);
  text-decoration: none;
  margin-top: 0.15rem;
  display: inline-block;
}

.activity-tx-link:hover {
  text-decoration: underline;
}
